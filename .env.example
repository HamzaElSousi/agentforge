# AgentForge — bring your own API key. Copy to .env and fill in.
# .env is gitignored and never committed.

# OpenRouter (default provider) — one key, hundreds of models.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: direct provider access (only needed if a pipeline uses provider: anthropic / openai)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: E2B cloud micro-VM sandbox backend (only if sandbox.backend: e2b)
E2B_API_KEY=

# Ollama needs no key — it runs locally at http://localhost:11434
